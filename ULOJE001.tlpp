#Include 'Protheus.ch'
#Include 'RestFul.CH'
#Include 'Totvs.ch'

/*/{Protheus.doc} ULOJE001
Fun’┐Į’┐Įo principal para consulta de Notas Fiscais (55) e NFC-e (65).
/*/
User Function ULOJE001(dDataProc)
    Local oRest         := Nil
    Local cUrlBase      := "https://api.grupoboticario.com.br"
    Local cResNfe       := "/global/v1/franchising/gb-stores-data/fiscal/invoices"
    Local cResNfce      := "/global/v1/franchising/gb-stores-data/sale/receipts"
    Local cQuery        := ""
    Local aHeaders      := {}
    Local cToken        := U_GETTOKENBOT()
    Local nDiasAnt      := SuperGetMv("HV_DIASANT",,1) // Par’┐Įmetro para definir quantos dias atr’┐Įs a consulta deve considerar, default 1 dia
    Local cDataOntem    := SubStr(DtoS(Date()-nDiasAnt),1,4) + "-" + SubStr(DtoS(Date()-nDiasAnt),5,2) + "-" + SubStr(DtoS(Date()-nDiasAnt),7,2)
    Local dZKDData      := Date()-nDiasAnt
    Local nTimeOut      := 120

    Private cCnpjSX5 := ""
    Private cDataPasta  := StrTran(cDataOntem, "-", "")

    Default dDataProc := CTOD("")

    DbSelectArea("ZKD")
    ZKD->(DbSetOrder(1))//ZKD_FILDES+ZKD_ID

    If !Empty(dDataProc)
        cDataOntem  := SubStr(DtoS(dDataProc),1,4) + "-" + SubStr(DtoS(dDataProc),5,2) + "-" + SubStr(DtoS(dDataProc),7,2)
        cDataPasta  := StrTran(cDataOntem, "-", "")
        dZKDData    := dDataProc
        // return
    EndIf

    // Valida’┐Į’┐Įo inicial do Token
    If Empty(cToken)
        ConOut("[ULOJE001] Falha critica: Token nao obtido.")
        Return
    EndIf

    // Instancia a classe REST
    oRest := FWRest():New(cUrlBase)
    oRest:SetTimeOut(nTimeOut)
    //-------------------------------------------------------------------
    // 1. CONSULTA NF-e (Modelo 55) - Endpoint de Invoices (paginado)
    //-------------------------------------------------------------------
    ConOut("[ULOJE001] Iniciando consulta NF-e (55)...")

    cQuery := "?invoice.updatedAt=" + cDataOntem
    // cQuery += "&situation=EFETIVADA"
    // cQuery += "&classification=VENDA"
    cQuery += "&invoice.fiscalOperationId=2"

    aHeaders := {}
    AAdd(aHeaders, 'Authorization: Bearer ' + cToken)
    AAdd(aHeaders, 'Accept: application/json')

    If ConsultaPag(oRest, cResNfe, cQuery, aHeaders, "NFE", dZKDData)
        ConOut("[ULOJE001] NF-e processadas com sucesso.")
    EndIf

    //-------------------------------------------------------------------
    // 2. CONSULTA NFC-e (Modelo 65) - Endpoint de Receipts (paginado)
    //-------------------------------------------------------------------
    ConOut("[ULOJE001] Iniciando consulta NFC-e (65)...")

    cQuery := "?receipt.saleDate=" + cDataOntem
    cQuery += "&receipt.InvoiceXMLStatus=AUTORIZADA"

    If ConsultaPag(oRest, cResNfce, cQuery, aHeaders, "NFCE", dZKDData)
        ConOut("[ULOJE001] NFC-e processadas com sucesso.")
    EndIf

Return

/*/{Protheus.doc} GETTOKENBOT
Obt’┐Įm o token JWT via POST (x-www-form-urlencoded)
/*/
User Function GETTOKENBOT()
    Local cUrl          := "https://api.grupoboticario.com.br/global/v2/jwt-token/token?grant_type=client_credentials"
    Local cResponse     := "" 
    Local cHeaderRet    := "" 
    Local nTimeOut      := 120
    Local aHeadOut      := {}
    Local cBody         := ""
    Local oJson         := JsonObject():New()
    Local cToken        := ""
    
    // Header obrigat’┐Įrio para o tipo de autentica’┐Į’┐Įo do Botic’┐Įrio
    AAdd(aHeadOut, 'Content-Type: application/x-www-form-urlencoded')
    
    // Montagem do corpo com Client ID e Secret
    cBody := "client_id=" + SuperGetMv("HV_CLIIDBT",,"88ymKwAUNfu06sD85i0RiokCxWGSkFBkx9ytgI5y1ZKxX3OQ") 
    cBody += "&client_secret=" + SuperGetMv("HV_CLISTBT",,"YDFz43qAzL6ApNIKVCxu3dAmS9GWOqJbcc2aPnFDkmEaBXexSpsHGfcItg56i2dE")

    cResponse := HttpPost(cUrl, "", cBody, nTimeOut, aHeadOut, @cHeaderRet)

    If !Empty(cResponse)
        oJson:FromJson(cResponse)
        If oJson:HasProperty("access_token")
            cToken := oJson["access_token"]
            ConOut("[GETTOKENBOT] Token obtido com sucesso.")
        EndIf
    Else
        ConOut("[GETTOKENBOT] Erro no POST: n’┐Įo foi poss’┐Įvel obter resposta do servidor.")
    EndIf

Return cToken

/*/{Protheus.doc} ConsultaPag
Percorre todas as paginas do endpoint informado (controle via campos start/count/total
da resposta da API) e grava cada item retornado na ZKD atraves da GravaZKD.
Renova o token e repete a pagina em caso de falha no GET (ex.: token expirado).
/*/
Static Function ConsultaPag(oRest, cResource, cQueryBase, aHeaders, cTipo, dZKDData)
    Local oJson     := Nil
    Local aItems    := {}
    Local cResponse := ""
    Local cErro     := ""
    Local cNovoTk   := ""
    Local nStart    := 0
    Local nTotal    := 0
    Local nCount    := 0
    Local nPagina   := 0
    Local nMaxPag   := 1000 // Salvaguarda contra laco infinito
    Local nI        := 0
    Local lRenovou  := .F.
    Local lRet      := .T.

    While nPagina < nMaxPag
        nPagina++
        oRest:SetPath(cResource + cQueryBase + "&start=" + cValToChar(nStart))

        If !oRest:Get(aHeaders)
            If !lRenovou
                // O token pode ter expirado durante o processamento; renova e repete a pagina
                ConOut("[ULOJE001] Falha no GET " + cTipo + " (start=" + cValToChar(nStart) + "). Renovando token para nova tentativa...")
                cNovoTk := U_GETTOKENBOT()
                If !Empty(cNovoTk)
                    aSize(aHeaders, 0)
                    AAdd(aHeaders, 'Authorization: Bearer ' + cNovoTk)
                    AAdd(aHeaders, 'Accept: application/json')
                EndIf
                lRenovou := .T.
                Loop
            EndIf
            ConOut("[ULOJE001] Erro na consulta " + cTipo + " (start=" + cValToChar(nStart) + "): " + oRest:GetLastError())
            lRet := .F.
            Exit
        EndIf

        lRenovou := .F. // Sucesso: libera nova renovacao para paginas futuras

        cResponse := oRest:GetResult()
        oJson     := JsonObject():New()
        cErro     := oJson:FromJson(cResponse)

        If !Empty(cErro)
            ConOut("[ULOJE001] Erro JSON " + cTipo + " (start=" + cValToChar(nStart) + "): " + cErro)
            lRet := .F.
            Exit
        EndIf

        nTotal := 0
        aItems := {}

        If oJson:HasProperty("total")
            If ValType(oJson["total"]) == "N"
                nTotal := oJson["total"]
            EndIf
        EndIf

        If oJson:HasProperty("items")
            If ValType(oJson["items"]) == "A"
                aItems := oJson["items"]
            EndIf
        EndIf

        nCount := Len(aItems)

        // Sem total, processa a pagina recebida e encerra de forma controlada
        If nTotal == 0 .And. nCount > 0
            nTotal := nStart + nCount
        EndIf

        ConOut("[ULOJE001] " + cTipo + ": processando registros " + cValToChar(nStart + 1) + " a " + cValToChar(nStart + nCount) + " de " + cValToChar(nTotal) + ".")

        For nI := 1 To nCount
            GravaZKD(aItems[nI], cTipo, dZKDData)
        Next nI

        nStart += nCount

        If nCount == 0 .Or. nStart >= nTotal
            Exit // Ultima pagina alcancada ou resposta vazia
        EndIf
    EndDo

    If lRet .And. nPagina >= nMaxPag .And. nStart < nTotal
        ConOut("[ULOJE001] Atencao: limite de paginas atingido para " + cTipo + ". Importacao possivelmente incompleta (" + cValToChar(nStart) + " de " + cValToChar(nTotal) + ").")
    EndIf
Return lRet

Static Function GravaZKD(oItem,cTipo,dZKDData)
    Local oModel    := FWLoadModel("ULOJA001") // Carrega o modelo definido no seu fonte
    Local nOp       := 3 // Opera’┐Į’┐Įo de Inclus’┐Įo (MODEL_OPERATION_INSERT)
    Local lRet      := .F.
    Local aErro     := {}
    Local cFilDestino := filDestino(oItem['storeId'])
    Local lKey      := Iif(cTipo == "NFE",oItem:HasProperty("key"),oItem:HasProperty("eletronicKey"))
    Local cKey      := Iif(lKey,Iif(cTipo == "NFE",oItem['key'],oItem['eletronicKey']),"")
    Local lJaExiste := .F.
    Local cXML      := ""
    Local cView     := ""
    Local cCgc      := ""
    Local cStXml    := ""
    Local cCanal    := ""
    Local cFPag     := ""
    Local nP        := 0

    // A propriedade pode existir no JSON com valor null (ex.: documento sem chave gerada/autorizada)
    If ValType(cKey) != "C" .Or. Empty(cKey)
        lKey := .F.
        cKey := ""
    EndIf

    // Verifica se o registro ja existe antes de decidir se refaz as buscas caras (XML/View/CGC)
    If lKey .and. !Empty(cFilDestino) .and. !Empty(cKey)
        lJaExiste := ZKD->(DbSeek(cFilDestino + cKey))
    EndIf

    If lJaExiste .And. !Empty(ZKD->ZKD_XML) .And. !Empty(ZKD->ZKD_VIEW)
        // Ja tem XML e View gravados: reaproveita em vez de bater de novo em disco/APIs
        cXML  := ZKD->ZKD_XML
        cView := ZKD->ZKD_VIEW
        cCgc  := ZKD->ZKD_CGC
    Else
        cXML  := Iif(lKey,retXml(cKey,lKey),"")
        cView := retView(oItem,cKey,cXML)
        cCgc  := retCgc(cXML,cKey)
    EndIf

    If cTipo == "NFCE"
        cStXml := Iif(oItem:HasProperty("invoiceXMLStatus"),  oItem['invoiceXMLStatus'],  "")
        cCanal := Iif(oItem:HasProperty("channelDescription"),oItem['channelDescription'],"")

        // paymentMethodDescription fica dentro do array "payments"; pega a primeira ocorrencia
        If oItem:HasProperty("payments")
            For nP := 1 To Len(oItem['payments'])
                If oItem['payments'][nP]:HasProperty("paymentMethodDescription")
                    cFPag := oItem['payments'][nP]['paymentMethodDescription']
                    Exit
                EndIf
            Next nP
        EndIf
    Else // NFE - payload de invoices nao tem invoiceXMLStatus/channelDescription/payments
        cStXml := Iif(oItem:HasProperty("situation"),        oItem['situation'],        "")
        cCanal := Iif(oItem:HasProperty("importType"),       oItem['importType'],       "")
        cFPag  := Iif(oItem:HasProperty("paymentCondition"), oItem['paymentCondition'], "")
    EndIf

    // Propriedades podem existir no JSON com valor null; normaliza para string vazia
    If ValType(cStXml) != "C"
        cStXml := ""
    EndIf
    If ValType(cCanal) != "C"
        cCanal := ""
    EndIf
    If ValType(cFPag) != "C"
        cFPag := ""
    EndIf

    If lKey .and. !Empty(cFilDestino) .and. !Empty(cKey) /*TESTE*/ //.and. cKey == "29260114378160001740650270000018831000018846"

        If lJaExiste
            nOp := 4 // Se achou, muda para Altera’┐Į’┐Įo (MODEL_OPERATION_UPDATE)
            ConOut("[ULOJE001] Registro encontrado. Alterando: " + cKey)
        Else
            nOp := 3 // Se n’┐Įo achou, mant’┐Įm Inclus’┐Įo
            ConOut("[ULOJE001] Registro n’┐Įo encontrado. Incluindo: " + cKey)
        EndIf

        // Ativa o modelo em modo de inclus’┐Įo
        oModel:SetOperation(nOp)
        oModel:Activate()
        
        If nOp == 3
            oModel:SetValue('ZKDMASTER', 'ZKD_ID',          cKey)  
            oModel:SetValue('ZKDMASTER', 'ZKD_DATA',        dZKDData) // Data de ontem, mesma data da consulta na API
            oModel:SetValue('ZKDMASTER', 'ZKD_TIPO',        cTipo)
            oModel:SetValue('ZKDMASTER', 'ZKD_HIST',        "--------"+DTOC(Date())+" "+SubStr(Time(),1,8)+"--------"+Chr(13) + Chr(10)+"Registro importado com sucesso.")
            oModel:SetValue('ZKDMASTER', 'ZKD_STATUS',      "R") 
        Else
            oModel:SetValue('ZKDMASTER', 'ZKD_HIST',        AllTrim(oModel:GetValue('ZKDMASTER', 'ZKD_HIST')) + CRLF +"--------"+DTOC(Date())+" "+SubStr(Time(),1,8)+"--------"+Chr(13) + Chr(10)+"Registro alterado com sucesso.")
        EndIf
        oModel:SetValue('ZKDMASTER', 'ZKD_JSON',        oItem:toJson())
        oModel:SetValue('ZKDMASTER', 'ZKD_XML',         cXML)
        oModel:SetValue('ZKDMASTER', 'ZKD_VIEW',        cView)
        oModel:SetValue('ZKDMASTER', 'ZKD_CGC',         cCgc)
        oModel:SetValue('ZKDMASTER', 'ZKD_FILDES',      cFilDestino)
        oModel:SetValue('ZKDMASTER', 'ZKD_STXML',       cStXml)
        oModel:SetValue('ZKDMASTER', 'ZKD_CANAL',       cCanal)
        oModel:SetValue('ZKDMASTER', 'ZKD_FPAG',        cFPag)

        // Valida e grava os dados
        If oModel:VldData()
            If oModel:CommitData()
                ConOut("[ULOJE001] Registro gravado com sucesso: " + cKey)
                lRet := .T.
            Else
                aErro := oModel:GetErrorMessage()
                ConOut("[ULOJE001] Erro no Commit: " + aErro[4]) // Descri’┐Į’┐Įo do erro
            EndIf
        Else
            aErro := oModel:GetErrorMessage()
            ConOut("[ULOJE001] Erro na Validacao: " + aErro[4])
        EndIf
    Else
        ConOut("[ULOJE001] Item ignorado: chave ('key'/'eletronicKey') ausente ou nula no JSON, ou filial de destino nao localizada.")
    EndIf

    // Encerra o modelo para liberar mem’┐Įria
    oModel:DeActivate()
    
Return lRet

/*/{Protheus.doc} filDestino
Dado o storeId da API, localiza a filial correspondente para gravar o registro na tabela ZKD com a filial correta.
/*/
Static Function filDestino(nStoreId)
    Local cStoreId := ""
    Local cFilRet  := ""
    Local nPos     := 0
    Local aEmpresas := {}

    // Reinicia a variavel privada para nao reaproveitar o CNPJ do item anterior
    cCnpjSX5 := ""

    // storeId pode vir nulo ou como texto no JSON
    If ValType(nStoreId) == "N"
        cStoreId := Padr(AllTrim(Str(nStoreId)), Len(SX5->X5_CHAVE))
    ElseIf ValType(nStoreId) == "C"
        cStoreId := Padr(AllTrim(nStoreId), Len(SX5->X5_CHAVE))
    Else
        Return cFilRet
    EndIf

    // 1. Busca o CNPJ na tabela SX5 (Sub-tabela ZX)
    DbSelectArea("SX5")
    SX5->(DbSetOrder(1)) // X5_FILIAL + X5_TABELA + X5_CHAVE

    If SX5->(DbSeek(xFilial("SX5") + "ZX" + cStoreId))
        // Pega o CNPJ que gravamos na descri’┐Į’┐Įo (removendo espa’┐Įos)
        cCnpjSX5 := AllTrim(SX5->X5_DESCRI)
    EndIf

    // 2. Localiza no Array da FwLoadSM0
    If !Empty(cCnpjSX5)
        aEmpresas := FwLoadSM0() // Carrega a tabela de empresas em mem’┐Įria

        // Faz o aScan procurando o CNPJ na posi’┐Į’┐Įo 18 de cada linha
        nPos := aScan(aEmpresas, {|x| AllTrim(x[18]) == cCnpjSX5})

        If nPos > 0
            // Se encontrou (nPos > 0), extra’┐Įmos o c’┐Įdigo da filial na posi’┐Į’┐Įo 4
            cFilRet := AllTrim(aEmpresas[nPos][3])+AllTrim(aEmpresas[nPos][4])+AllTrim(aEmpresas[nPos][5])
        EndIf
    EndIf

    // Retorna o c’┐Įdigo da filial encontrado ou "" se n’┐Įo houver correspond’┐Įncia
Return cFilRet

/*/{Protheus.doc} retXml
Localiza o arquivo XML, carrega em objeto e retorna o conte’┐Įdo como string.
/*/
Static Function retXml(cKey,lKey)
    Local cDirBase   := "\fiscal_xmls\" + cDataPasta + "\docs-fiscais\"
    Local aDirID     := Directory(cDirBase + "*.*", "D")
    Local cID        := ""
    Local nI         := 0
    Local nS         := 0
    Local cPathFinal := ""
    Local aFiles     := {}
    Local cArquivo   := ""
    Local cXmlStr    := "" // String que ser’┐Į retornada
    Local oXml       := Nil
    Local cError     := ""
    Local cWarning   := ""
    Local aSubPastas := {"saida", "importacao"}

    If lKey .And. ValType(cKey) == "C" .And. !Empty(cKey)
        cKey := Lower(cKey)
        // 1. Localiza a pasta do ID din’┐Įmico
        For nI := 1 To Len(aDirID)
            If "D" $ aDirID[nI][5] .And. !(aDirID[nI][1] == "." .Or. aDirID[nI][1] == "..")
                cID := Lower(aDirID[nI][1])
                Exit
            EndIf
        Next nI

        If !Empty(cID)
            // 2. Procura em "saida" e "importacao", independente do tipo do documento (NFE/NFCE)
            For nS := 1 To Len(aSubPastas)
                // Monta o caminho usando as vari’┐Įveis privadas cCnpjSX5 e cDataPasta
                cPathFinal := cDirBase + cID + "\" + cCnpjSX5 + "\" + aSubPastas[nS] + "\"

                If !ExistDir(cPathFinal) .And. ExistDir(cDirBase + cCnpjSX5 + "\" + aSubPastas[nS] + "\")
                    // Estrutura sem pasta de ID (cargas antigas, sem a camada de ID dinamico)
                    cPathFinal := cDirBase + cCnpjSX5 + "\" + aSubPastas[nS] + "\"
                EndIf

                If ExistDir(cPathFinal)
                    aFiles := Directory(cPathFinal + "*.xml")

                    For nI := 1 To Len(aFiles)
                        // Procura o arquivo que cont’┐Įm a chave solicitada
                        If cKey $ Lower(aFiles[nI][1])
                            cArquivo := cPathFinal + aFiles[nI][1]

                            // A. L’┐Į o arquivo f’┐Įsico e joga para uma string
                            cXmlStr := MemoRead(cArquivo)

                            If !Empty(cXmlStr)
                                // B. "Joga" a string para um objeto XML (Parser)
                                // O "_" define o separador de tags
                                oXml := XmlParser(cXmlStr, "_", @cError, @cWarning)

                                If oXml == Nil
                                    ConOut("[ULOJE003] Erro no Parse do XML: " + cError)
                                Else
                                    ConOut("[ULOJE003] XML carregado em objeto com sucesso.")
                                    // Aqui o objeto oXml est’┐Į pronto para uso, ex: oXml:_NfeProc:_Nfe...
                                EndIf
                            EndIf

                            Exit // Arquivo encontrado, encerra o loop de arquivos desta subpasta
                        EndIf
                    Next nI
                EndIf

                If !Empty(cXmlStr)
                    Exit // Ja encontrou o XML, nao precisa testar a outra subpasta
                EndIf
            Next nS
        EndIf
    Else
        ConOut("[ULOJE003] Erro: Propriedade 'key' nao encontrada no item JSON.")
    EndIf

    // Retorna o conte’┐Įdo lido (string) para quem chamou a fun’┐Į’┐Įo
Return cXmlStr

/*/{Protheus.doc} retView
Localiza a view financeira, carrega em objeto e retorna o conte’┐Įdo como string.
/*/
Static Function retView(oJson,cNumDoc,cXML)
    Local cItem     := ""
    Local cView     := ""
    Local cError    := ""
    Local cWarning  := ""
    Local aItens    := {}
    Local nX        := 0
    Local nY        := 0
    Local oFinanceiro := Nil
    Local oXml      := Nil
    Local cIdSite   := ""
    Local cCaut     := ""
    Local cMerchant := ""
    Default cXML    := ""
    // Busca itens do JSON
    If oJson:Hasproperty("items")
        aItens := oJson['items']
    Else
        conout( "[ULOJE001]: Itens n’┐Įo encontrados no JSON do documento [" + cNumDoc + "].")
    EndIf
    // Pedido Site: o ID do OMNI vem embutido em "observation" (payload de NF-e nao tem externalId)
    If oJson:Hasproperty("observation") .And. ValType(oJson["observation"]) == "C"
        cIdSite := ExtraiIdSite(oJson["observation"])
        If !Empty(cIdSite)
            oFinanceiro := U_ULOJE004(cIdSite,'')
        EndIf
    EndIf
    // Consulta por orderNumber
    If oFinanceiro == Nil
        For nX := 1 To Len(aItens)
            cItem := StrZero(nX, TamSX3("L2_ITEM")[1])
            If aItens[nX]:Hasproperty("orderNumber")
                If !Empty(aItens[nX]["orderNumber"])
                    oFinanceiro := U_ULOJE004(aItens[nX]["orderNumber"],'')
                    If oFinanceiro != Nil
                        exit
                    Else
                        conout("[ULOJE001]: A view financeira n’┐Įo foi encontrada para o item [" + cItem + "] do documento [" + cNumDoc + "].")
                    EndIf
                Else
                    conout("[ULOJE001]: N’┐Įmero do pedido vazio para o item [" + cItem + "] do documento [" + cNumDoc + "]. Ignorando consulta ’┐Į API.")
                EndIf
            Else
                conout("[ULOJE001]: N’┐Įmero do pedido n’┐Įo encontrado para o item [" + cItem + "] do documento [" + cNumDoc + "]. Ignorando consulta ’┐Į API.")
            EndIf
        Next
    EndIf
    // Consulta por authorizationNsu
    If oFinanceiro == Nil
        If oJson:Hasproperty("payments")
            For nX := 1 to Len(oJson["payments"])
                If oJson["payments"][nX]:Hasproperty("authorizationNsu")		
                    If !Empty(oJson["payments"][nX]["authorizationNsu"]) /*TESTE*/ //.and. oJson["id"] == "002469-027-1768014000000-23702"
                        oFinanceiro := U_ULOJE004(oJson["payments"][nX]["authorizationNsu"],oJson["payments"][nX]["paymentMethodDescription"])
                        If oFinanceiro != Nil
                            exit
                        Else
                            oFinanceiro := U_ULOJE004(oJson["payments"][nX]["cardAuthorization"],oJson["payments"][nX]["paymentMethodDescription"],"authorization_code")
                            If oFinanceiro != Nil
                                exit
                            Else
                                conout("[ULOJE001]: A view financeira n’┐Įo foi encontrada para o item [" + cItem + "] do documento [" + cNumDoc + "].")
                            EndIf
                        EndIf
                    EndIf
                EndIf
            Next
        EndIf
    EndIf
    // Busca por external_id para OMNI
    If oFinanceiro == Nil
        If oJson:Hasproperty("externalId") .and. oJson:Hasproperty("payments")
            For nX := 1 to Len(oJson["payments"])
                If oJson["payments"][nX]:Hasproperty("paymentMethodDescription")
                    If !Empty(oJson["externalId"]) .and. !Empty(oJson["payments"][nX]["paymentMethodDescription"])
                        oFinanceiro := U_ULOJE004(StrTran(oJson["externalId"],"-F1",""),oJson["payments"][nX]["paymentMethodDescription"])
                        If oFinanceiro != Nil
                            exit
                        Else
                            conout("[ULOJE001]: A view financeira n’┐Įo foi encontrada para o item [" + cItem + "] do documento [" + cNumDoc + "].")
                        EndIf
                    EndIf
                EndIf
            Next
        EndIf
    EndIf
    // Consulta por authorization_code
    If oFinanceiro == Nil
        If oJson:Hasproperty("payments")
            For nX := 1 to Len(oJson["payments"])
                If oJson["payments"][nX]:Hasproperty("paymentMethodDescription")		
                    If !Empty(oJson["payments"][nX]["paymentMethodDescription"])	
                        If 	AllTrim(oJson["payments"][nX]["paymentMethodDescription"]) == "PIX NO PDV"		
                            If !Empty(cXML)
                                oXml := XmlParser(cXML, "_", @cError, @cWarning)
                                If oXml <> Nil
                                    If AttIsMemberOf(oXml, "_NFEPROC")
                                        If AttIsMemberOf(oXml:_NFEPROC, "_NFE")
                                            If AttIsMemberOf(oXml:_NFEPROC:_NFE, "_INFNFE")
                                                If AttIsMemberOf(oXml:_NFEPROC:_NFE:_INFNFE, "_INFADIC")
                                                    If AttIsMemberOf(oXml:_NFEPROC:_NFE:_INFNFE:_INFADIC, "_OBSCONT")
                                                        If Len(oXml:_NFEPROC:_NFE:_INFNFE:_INFADIC:_OBSCONT) > 0
                                                            For nY := 1 to Len(oXml:_NFEPROC:_NFE:_INFNFE:_INFADIC:_OBSCONT)
                                                                If oXml:_NFEPROC:_NFE:_INFNFE:_INFADIC:_OBSCONT[nY]:_XCAMPO:TEXT == "idPix"
                                                                    oFinanceiro := U_ULOJE004(oXml:_NFEPROC:_NFE:_INFNFE:_INFADIC:_OBSCONT[nY]:_XTEXTO:TEXT,oJson["payments"][nX]["paymentMethodDescription"])
                                                                    If oFinanceiro != Nil
                                                                        exit
                                                                    Else
                                                                        conout("[ULOJE001]: A view financeira n’┐Įo foi encontrada para o item [" + cItem + "] do documento [" + cNumDoc + "].")
                                                                    EndIf
                                                                EndIf
                                                            Next
                                                        EndIf
                                                    EndIf
                                                EndIf
                                            EndIf
                                        EndIf
                                    EndIf
                                EndIf
                            EndIf
                        EndIf
                    EndIf
                EndIf
            Next
        EndIf
    EndIf
    // Se a view financeira foi encontrada, converte para JSON e retorna, sen’┐Įo retorna string vazia
    If oFinanceiro == Nil .And. !Empty(cXML) .And. oJson:HasProperty("storeId")
        cCaut := RetCautXml(cXML)

        If !Empty(cCaut)
            cMerchant := PadL(AllTrim(cValToChar(oJson["storeId"])), 8, "0")
            oFinanceiro := U_ULOJE004MZ(cCaut, cMerchant)

            If oFinanceiro == Nil
                ConOut("[ULOJE001]: Fallback Mooz nao encontrou view para merchant [" + cMerchant + "] authorization_code [" + cCaut + "] documento [" + cNumDoc + "].")
            EndIf
        Else
            ConOut("[ULOJE001]: cAut nao encontrado no XML do documento [" + cNumDoc + "].")
        EndIf
    EndIf

    If oFinanceiro <> Nil
        cView := oFinanceiro:toJson()
    EndIf
Return cView

Static Function RetCautXml(cXML)
    Local cError    := ""
    Local cWarning  := ""
    Local cCaut     := ""
    Local oXml      := XmlParser(cXML, "_", @cError, @cWarning)
    Local oRaizNFe  := Nil
    Local oInfNfe   := Nil
    Local oPag      := Nil
    Local uDetPag   := Nil
    Local nX        := 0

    If oXml != Nil
        If AttIsMemberOf(oXml, "_NFEPROC")
            oRaizNFe := oXml:_NFEPROC
        Else
            oRaizNFe := oXml
        EndIf

        If AttIsMemberOf(oRaizNFe, "_NFE") .And. AttIsMemberOf(oRaizNFe:_NFE, "_INFNFE")
            oInfNfe := oRaizNFe:_NFE:_INFNFE
        EndIf

        If oInfNfe != Nil .And. AttIsMemberOf(oInfNfe, "_PAG")
            oPag := oInfNfe:_PAG

            If AttIsMemberOf(oPag, "_DETPAG")
                uDetPag := oPag:_DETPAG

                If ValType(uDetPag) == "A"
                    For nX := 1 To Len(uDetPag)
                        cCaut := CautDetPag(uDetPag[nX])
                        If !Empty(cCaut)
                            Exit
                        EndIf
                    Next nX
                Else
                    cCaut := CautDetPag(uDetPag)
                EndIf
            EndIf
        EndIf
    EndIf

    If Empty(cCaut)
        cCaut := ExtraiTagXml(cXML, "cAut")
    EndIf

Return cCaut

Static Function CautDetPag(oDetPag)
    Local cCaut := ""

    If oDetPag != Nil .And. AttIsMemberOf(oDetPag, "_CARD")
        If AttIsMemberOf(oDetPag:_CARD, "_CAUT")
            cCaut := AllTrim(oDetPag:_CARD:_CAUT:TEXT)
        EndIf
    EndIf

Return cCaut

Static Function ExtraiTagXml(cXML, cTag)
    Local cXmlUpper := Upper(cXML)
    Local cIniTag   := "<" + Upper(cTag) + ">"
    Local cFimTag   := "</" + Upper(cTag) + ">"
    Local nIni      := At(cIniTag, cXmlUpper)
    Local nFim      := 0
    Local cRet      := ""

    If nIni > 0
        nIni += Len(cIniTag)
        nFim := At(cFimTag, SubStr(cXmlUpper, nIni))

        If nFim > 0
            cRet := AllTrim(SubStr(cXML, nIni, nFim - 1))
        EndIf
    EndIf

Return cRet

/*/{Protheus.doc} ExtraiIdSite
Extrai o identificador do pedido site a partir do texto de observacao da nota
fiscal, no formato "...Pedido Site <ID>...". Retorna "" se nao encontrar.
/*/
Static Function ExtraiIdSite(cObservacao)
    Local cMarcador := "PEDIDO SITE"
    Local cObsUpper := Upper(cObservacao)
    Local nPos      := At(cMarcador, cObsUpper)
    Local cResto    := ""
    Local cId       := ""
    Local nC        := 0
    Local cChar     := ""

    If nPos > 0
        cResto := AllTrim(SubStr(cObservacao, nPos + Len(cMarcador)))

        For nC := 1 To Len(cResto)
            cChar := Upper(SubStr(cResto, nC, 1))
            If (cChar >= "0" .And. cChar <= "9") .Or. (cChar >= "A" .And. cChar <= "Z")
                cId += cChar
            Else
                Exit
            EndIf
        Next nC
    EndIf
Return cId

/*/{Protheus.doc} retCgc
Localiza o CPF/CNPJ do cliente no XML, carrega em objeto e retorna o conte’┐Įdo como string.
/*/
Static Function retCgc(cXml,cNumDoc)
    Local cCliPad 		:= "999999"//PadR(SuperGetMV("MV_CLIPAD")) // Cliente padrao
	Local cLojPad 		:= "01"//PadR(SuperGetMV("MV_LOJAPAD") , TamSx3("A1_LOJA")[1]) // loja padrao
    Local cCGC          := ""
    Local lCliente 		:= .F.
    Local cError        := ""
    Local cWarning      := ""
    Local oInfNfe := Nil
    Local oRaizNFe := Nil
    Local oDest
    Local oXml := XmlParser(cXml, "_", @cError, @cWarning)
    // Busca cliente pelo XML
    If oXml != Nil
        // Caminho base at’┐Į o INFNFE para reduzir a verbosidade
        // Alguns XMLs (ex.: pasta importacao) vem sem o envelope _NFEPROC (sem protocolo de autorizacao)
        If AttIsMemberOf(oXml, "_NFEPROC")
            oRaizNFe := oXml:_NFEPROC
        Else
            oRaizNFe := oXml
        EndIf

        If AttIsMemberOf(oRaizNFe, "_NFE") .And. AttIsMemberOf(oRaizNFe:_NFE, "_INFNFE")
            oInfNfe := oRaizNFe:_NFE:_INFNFE
        EndIf
    EndIf

    If oInfNfe != Nil
        oDest   := Nil
        cCGC    := ""
        // 1. Verifica se o n’┐Į DEST existe dentro de INFNFE
        If AttIsMemberOf(oInfNfe, "_DEST")
            oDest := oInfNfe:_DEST							
            // 2. Verifica se ’┐Į CPF ou CNPJ dentro de DEST
            If AttIsMemberOf(oDest, "_CPF")
                cCGC := oDest:_CPF:TEXT								
            ElseIf AttIsMemberOf(oDest, "_CNPJ")
                cCGC := oDest:_CNPJ:TEXT
            EndIf
            // 3. Executa a busca se encontrou o documento
            SA1->(DbSetOrder(3))						
            If !Empty(cCGC) .And. SA1->(DbSeek(xFilial('SA1') + cCGC))
                lCliente := .T.
            EndIf
        EndIf
    EndIf
    // Busca cliente padr’┐Įo
    If !lCliente
        SA1->(DbSetOrder(1)) // A1_COD+A1_LOJA
        If SA1->(DbSeek(xFilial('SA1')+cCliPad+cLojPad))
            cCGC := SA1->A1_CGC
            conout("[ULOJE001]: CPF/CNPJ do cliente n’┐Įo encontrado no XML do documento [" + cNumDoc + "]. Usando cliente padr’┐Įo.")
            lCliente := .T.
        Else
            conout("[ULOJE001]: Cliente padr’┐Įo do MV_CLIPAD n’┐Įo encontrado. Verificar cadastro. Documento [" + cNumDoc + "].")
        EndIf
    Else
        cCGC := ""
    EndIf
Return cCGC

