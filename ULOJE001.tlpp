    AAdd(aDados, {"20444", "26842846001649"})
    AAdd(aDados, {"12819", "08489643001981"})
    AAdd(aDados, {"17842", "08489643003763"})
    AAdd(aDados, {"20007", "08489643003925"})
    AAdd(aDados, {"21382", "08489643006860"})

    DbSelectArea("SX5")
    SX5->(DbSetOrder(1)) // X5_FILIAL + X5_TABELA + X5_CHAVE

    Begin Transaction
        For nI := 1 To Len(aDados)
            
            cChave := Padr(aDados[nI][1], Len(SX5->X5_CHAVE))
            cCnpj  := aDados[nI][2]

            // Verifica se o BPCS n’┐Įo est’┐Į vazio antes de tentar gravar
            If !Empty(aDados[nI][1])
                If !SX5->(DbSeek(cFilSX5 + cTabela + cChave))
                    RecLock("SX5", .T.)
                    SX5->X5_FILIAL := cFilSX5
                    SX5->X5_TABELA := cTabela
                    SX5->X5_CHAVE  := cChave
                Else
                    RecLock("SX5", .F.)
                EndIf

                SX5->X5_DESCRI := cCnpj
                SX5->(MsUnlock())
            EndIf
        Next nI
    End Transaction

    MsgInfo("Carga da tabela ZX finalizada com sucesso!", "Aviso")

Return

/*/{Protheus.doc} JLOJE001
Job para preparar o ambiente, configurar o RPC e chamar a fun’┐Į’┐Įo principal de consulta e grava’┐Į’┐Įo dos documentos fiscais.
/*/
User Function JLOJE001()
    Local dDataProc := SToD("20260101") 

    ConOut("[JLOJE001] Prerando ambiente.")
    RpcSetEnv("01","010101")
    ConOut("[JLOJE001] Ambiente configurado "+cFilAnt+".")
    
    While dDataProc <> Date()
        U_ULOJE001(dDataProc)
        dDataProc += 1
    EndDO
Return
